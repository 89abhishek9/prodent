          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content8\" group=\"Content\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"10\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Stylized\" name=\"stylizedCounters\">\n        <input type=\"checkbox\" title=\"Mark\" name=\"mark\" condition=\"stylizedCounters\">\n        <select title=\"Type\" name=\"countersType\" condition=\"stylizedCounters\">\n            <option value=\"default\" selected>Ð¡ircle Fill</option>\n            <option value=\"circle\">Circle</option>\n            <option value=\"square\">Square</option>\n        </select>\n        <input type=\"color\" name=\"iconColor\" title=\"Color\" value=\"#037953\">\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#ffffff\">\n    </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"counter-container col-md-12 col-lg-{{textWidth}}\">\n                <h4 class=\"mbr-section-title mbr-fonts-style mb-4\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\">\n                    Shape your future web project with the Mobirise app.\n                </h4>\n                <div class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\" data-multiline mbr-article>\n                    <ul>\n                        <li><b>Supplement Name: </b>ProDentim</li><li><b>Category: </b>Oral Health and Probiotic Support Formula</li><li><b>Designed For: </b>Adult Men &amp; Women (above 18)</li><li><b>Form: </b>Dissolvable Candy</li><li><b>Ingredients: </b>3.5 Billion Probiotic Strains (Lactobacillus Paracasei, Lactobacillus Reuteri, Bifidobacterium Lactis BL-04, and more), Inulin, Malic Acid, Peppermint, and other natural nutrients.</li><li><b>Benefits Offered: </b>Supports Healthy Teeth and Gums, Promotes Oral Microbiome Balance, Improves Digestion, Enhances Respiratory Health, and Promotes Better Sleep.</li><li><b>Manufactured In: </b>The USA under an FDA-registered and GMP-certified facility.</li><li><b>Money Back Policy: </b>60 days</li><li><b>Availability: </b>Exclusively through the official website.</li><li><b>To Purchase: </b><a href=\"https://9fe542fduya2an5n6kobrfseeg.hop.clickbank.net/?&extclid=abhi135\" class=\"text-primary\">Click Here</a></li></ul><ul>\n                    </ul>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
