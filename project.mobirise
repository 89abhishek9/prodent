        {
          "_customTemplate": true,
          "_afterNavbarItem": false,
          "_customHTML": "<div style=\"text-align: center; margin: 40px; padding: 20px;\">\n    <p style=\"font-size: 32px; text-decoration: line-through; color: black; margin-bottom: 30px;\">Regular Price: $99/per bottle</p>\n    <p style=\"font-size: 40px; font-weight: bold; color: #232323; margin-bottom: 30px;\">Today's Price: $49/per bottle</p>\n    <a href=\"https://162c2c292gq08m6jzjic1rsbck.hop.clickbank.net/?&amp;campaign=prodien\" target=\"_blank\">\n        <button style=\"background-color: #ffeb3b; padding: 25px 60px; font-size: 26px; border: none; cursor: pointer; font-weight: bold; border-radius: 30px; color: #453a00;\" onmouseover=\"this.style.backgroundColor='#ffe144'; this.style.color='#ffffff';\" onmouseout=\"this.style.backgroundColor='#ffeb3b'; this.style.color='#453a00';\">\n            GET 78% DISCOUNT NOW\n        </button>\n    </a>\n</div>\n",
